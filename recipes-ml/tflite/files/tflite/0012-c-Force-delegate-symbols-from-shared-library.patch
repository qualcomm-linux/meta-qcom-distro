+#include <cstdio>
+
+#include "tensorflow/lite/delegates/xnnpack/xnnpack_delegate.h"
+#include "tensorflow/lite/delegates/gpu/delegate.h"
+#include "tensorflow/lite/tools/evaluation/utils.h"
+#include "tensorflow/lite/delegates/external/external_delegate.h"
+
+void dummy() {
+    char buf[64] = {0};
+#if TFLITE_BUILD_WITH_XNNPACK_DELEGATE
+    snprintf(buf, 64, "%p\n", TfLiteXNNPackDelegateCreate);
+    snprintf(buf, 64, "%p\n", TfLiteXNNPackDelegateDelete);
+#endif
+    snprintf(buf, 64, "%p\n", TfLiteExternalDelegateCreate);
+    snprintf(buf, 64, "%p\n", TfLiteExternalDelegateDelete);
+#if TFLITE_SUPPORTS_GPU_DELEGATE
+    snprintf(buf, 64, "%p\n", TfLiteGpuDelegateV2Create);
+    snprintf(buf, 64, "%p\n", TfLiteGpuDelegateV2Delete);
+#endif
+}
